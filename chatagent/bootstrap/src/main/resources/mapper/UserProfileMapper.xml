<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yulong.chatagent.support.persistence.mapper.UserProfileMapper">

    <resultMap id="BaseResultMap" type="com.yulong.chatagent.user.model.dto.UserProfileDTO">
        <id property="userId" column="user_id" jdbcType="VARCHAR"/>
        <result property="summary" column="summary" jdbcType="VARCHAR"/>
        <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
        <result property="updatedAt" column="updated_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT
            user_id,
            summary,
            created_at,
            updated_at
        FROM user_profile
        WHERE user_id = CAST(#{userId} AS uuid)
    </select>

    <insert id="insert" parameterType="com.yulong.chatagent.user.model.dto.UserProfileDTO">
        INSERT INTO user_profile (
            user_id,
            summary,
            created_at,
            updated_at
        )
        VALUES (
            CAST(#{userId} AS uuid),
            #{summary},
            #{createdAt},
            #{updatedAt}
        )
    </insert>

    <insert id="upsert" parameterType="com.yulong.chatagent.user.model.dto.UserProfileDTO">
        INSERT INTO user_profile (
            user_id,
            summary,
            created_at,
            updated_at
        )
        VALUES (
            CAST(#{userId} AS uuid),
            #{summary},
            COALESCE(#{createdAt}, NOW()),
            COALESCE(#{updatedAt}, NOW())
        )
        ON CONFLICT (user_id)
        DO UPDATE SET
            summary = EXCLUDED.summary,
            updated_at = NOW()
    </insert>
</mapper>
