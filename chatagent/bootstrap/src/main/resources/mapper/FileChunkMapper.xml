<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yulong.chatagent.support.persistence.mapper.FileChunkMapper">

    <resultMap id="BaseResultMap" type="com.yulong.chatagent.support.persistence.entity.FileChunk">
        <id property="id" column="id" jdbcType="VARCHAR"/>
        <result property="sessionFileId" column="session_file_id" jdbcType="VARCHAR"/>
        <result property="chunkIndex" column="chunk_index" jdbcType="INTEGER"/>
        <result property="content" column="content" jdbcType="VARCHAR"/>
        <result property="tokenCount" column="token_count" jdbcType="INTEGER"/>
        <result property="metadata" column="metadata" jdbcType="VARCHAR"/>
        <result property="enabled" column="enabled" jdbcType="BOOLEAN"/>
        <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
        <result property="updatedAt" column="updated_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insertBatch">
        INSERT INTO file_chunk (
            id,
            session_file_id,
            chunk_index,
            content,
            token_count,
            metadata,
            enabled,
            created_at,
            updated_at
        )
        VALUES
        <foreach collection="chunks" item="chunk" separator=",">
            (
                CAST(#{chunk.id} AS uuid),
                CAST(#{chunk.sessionFileId} AS uuid),
                #{chunk.chunkIndex},
                #{chunk.content},
                #{chunk.tokenCount},
                COALESCE(CAST(#{chunk.metadata} AS jsonb), '{}'::jsonb),
                #{chunk.enabled},
                #{chunk.createdAt},
                #{chunk.updatedAt}
            )
        </foreach>
    </insert>

    <select id="selectBySessionFileId" resultMap="BaseResultMap">
        SELECT
            id,
            session_file_id,
            chunk_index,
            content,
            token_count,
            metadata::text AS metadata,
            enabled,
            created_at,
            updated_at
        FROM file_chunk
        WHERE session_file_id = CAST(#{sessionFileId} AS uuid)
        ORDER BY chunk_index ASC
    </select>

    <delete id="deleteBySessionFileId">
        DELETE FROM file_chunk
        WHERE session_file_id = CAST(#{sessionFileId} AS uuid)
    </delete>

</mapper>
