<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yulong.chatagent.support.persistence.mapper.KnowledgeChunkMapper">

    <resultMap id="BaseResultMap" type="com.yulong.chatagent.support.persistence.entity.KnowledgeChunk">
        <id property="id" column="id" jdbcType="VARCHAR"/>
        <result property="knowledgeDocumentId" column="knowledge_document_id" jdbcType="VARCHAR"/>
        <result property="chunkIndex" column="chunk_index" jdbcType="INTEGER"/>
        <result property="content" column="content" jdbcType="VARCHAR"/>
        <result property="tokenCount" column="token_count" jdbcType="INTEGER"/>
        <result property="metadata" column="metadata" jdbcType="VARCHAR"/>
        <result property="enabled" column="enabled" jdbcType="BOOLEAN"/>
        <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
        <result property="updatedAt" column="updated_at" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insert" parameterType="com.yulong.chatagent.support.persistence.entity.KnowledgeChunk">
        INSERT INTO knowledge_chunk
        (id,
         knowledge_document_id,
         chunk_index,
         content,
         token_count,
         metadata,
         enabled,
         created_at,
         updated_at)
        VALUES (CAST(#{id} AS uuid),
                CAST(#{knowledgeDocumentId} AS uuid),
                #{chunkIndex},
                #{content},
                #{tokenCount},
                CAST(#{metadata} AS jsonb),
                #{enabled},
                #{createdAt},
                #{updatedAt})
    </insert>

    <select id="selectByKnowledgeDocumentId" resultMap="BaseResultMap">
        SELECT id,
               knowledge_document_id,
               chunk_index,
               content,
               token_count,
               metadata::text AS metadata,
               enabled,
               created_at,
               updated_at
        FROM knowledge_chunk
        WHERE knowledge_document_id = CAST(#{knowledgeDocumentId} AS uuid)
        ORDER BY chunk_index ASC
    </select>

    <delete id="deleteByKnowledgeDocumentId">
        DELETE
        FROM knowledge_chunk
        WHERE knowledge_document_id = CAST(#{knowledgeDocumentId} AS uuid)
    </delete>
</mapper>
