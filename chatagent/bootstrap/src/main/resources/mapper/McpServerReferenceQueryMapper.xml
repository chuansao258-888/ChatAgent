<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yulong.chatagent.support.persistence.mapper.McpServerReferenceQueryMapper">

    <resultMap id="ReferenceResultMap" type="com.yulong.chatagent.support.dto.McpToolReferenceDTO">
        <result property="referenceType" column="reference_type" jdbcType="VARCHAR"/>
        <result property="referenceId" column="reference_id" jdbcType="VARCHAR"/>
        <result property="referenceName" column="reference_name" jdbcType="VARCHAR"/>
        <result property="referencePath" column="reference_path" jdbcType="VARCHAR"/>
    </resultMap>

    <select id="selectAgentReferences" resultMap="ReferenceResultMap">
        SELECT
            'AGENT' AS reference_type,
            id::text AS reference_id,
            name AS reference_name,
            '/allowedTools' AS reference_path
        FROM agent
        WHERE jsonb_exists_any(
            COALESCE(allowed_tools, '[]'::jsonb),
            ARRAY[
                <foreach collection="toolNames" item="toolName" separator=",">
                    #{toolName}
                </foreach>
            ]::text[]
        )
    </select>

    <select id="selectIntentNodeReferences" resultMap="ReferenceResultMap">
        SELECT
            'INTENT_NODE' AS reference_type,
            id::text AS reference_id,
            name AS reference_name,
            '/allowedTools' AS reference_path
        FROM intent_node
        WHERE jsonb_exists_any(
            COALESCE(allowed_tools, '[]'::jsonb),
            ARRAY[
                <foreach collection="toolNames" item="toolName" separator=",">
                    #{toolName}
                </foreach>
            ]::text[]
        )
    </select>
</mapper>
