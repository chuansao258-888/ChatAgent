{
  "id": "rag-retrieval-v1",
  "version": "1",
  "primaryMetric": "ragRetrieval.ndcgAtK",
  "direction": "maximize",
  "parameters": [
    {
      "id": "topK",
      "classification": "quality-tunable",
      "type": "integer",
      "values": [3, 5, 8],
      "rationale": "Controls the final number of retrieval contexts."
    },
    {
      "id": "candidateK",
      "classification": "quality-tunable",
      "type": "integer",
      "values": [8, 12, 24],
      "rationale": "Controls the candidate pool before fusion and reranking."
    },
    {
      "id": "rrfK",
      "classification": "quality-tunable",
      "type": "integer",
      "values": [20, 60, 100],
      "rationale": "Controls reciprocal-rank-fusion smoothing."
    }
  ]
}
