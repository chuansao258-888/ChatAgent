{
  "id": "text-recall-v1",
  "version": "1",
  "primaryMetric": "textRecall.retrievalContextPhraseRecall",
  "direction": "maximize",
  "parameters": [
    {
      "id": "chunkSize",
      "classification": "quality-tunable",
      "type": "integer",
      "values": [1000, 2000, 4000],
      "rationale": "Controls the maximum visible-text chunk size."
    },
    {
      "id": "chunkOverlap",
      "classification": "quality-tunable",
      "type": "integer",
      "values": [0, 200, 400],
      "rationale": "Controls overlap used to preserve required phrases across chunk boundaries."
    },
    {
      "id": "topK",
      "classification": "quality-tunable",
      "type": "integer",
      "values": [1, 3, 5],
      "rationale": "Controls the number of retrieved text contexts."
    }
  ]
}
