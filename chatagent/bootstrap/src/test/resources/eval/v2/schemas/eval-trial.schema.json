{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatagent.local/eval/v2/eval-trial.schema.json",
  "title": "ChatAgent Evaluation Trial",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experimentId",
    "trialId",
    "parameterSpaceId",
    "configFingerprint",
    "randomSeed",
    "parameters",
    "status",
    "metrics"
  ],
  "properties": {
    "experimentId": { "type": "string", "minLength": 1 },
    "trialId": { "type": "string", "minLength": 1 },
    "parameterSpaceId": { "type": "string", "minLength": 1 },
    "configFingerprint": { "type": "string", "minLength": 1 },
    "randomSeed": { "type": "integer" },
    "parameters": { "type": "object" },
    "stage": { "type": "string", "enum": ["baseline", "sensitivity", "combination"] },
    "status": { "type": "string", "enum": ["completed", "failed", "skipped"] },
    "datasetHash": { "type": "string", "minLength": 1 },
    "splitHashes": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "codeSha": { "type": "string" },
    "models": { "type": "object" },
    "metrics": {
      "type": "object",
      "additionalProperties": { "type": ["number", "null"] }
    },
    "categoryMetrics": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "confidenceInterval": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "repeatedRunVariance": { "type": ["number", "null"] },
    "failureCount": { "type": "integer" },
    "gateFailures": { "type": "array", "items": { "type": "string" } },
    "latencyP95Ms": { "type": ["number", "null"] },
    "executionElapsedMs": { "type": ["number", "null"] },
    "costUsd": { "type": ["number", "null"] }
  }
}
