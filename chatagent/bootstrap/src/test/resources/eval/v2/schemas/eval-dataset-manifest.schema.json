{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatagent.local/eval/v2/eval-dataset-manifest.schema.json",
  "title": "ChatAgent Evaluation Dataset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "datasetId", "version", "sourceIds", "recordSchema", "localPath", "datasetHash", "splitManifestPath", "splitManifestHash", "recordCount", "groupCount", "splits"],
  "properties": {
    "schemaVersion": { "type": "integer" },
    "datasetId": { "type": "string", "minLength": 1 },
    "version": { "type": "integer" },
    "sourceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "recordSchema": { "type": "string", "minLength": 1 },
    "localPath": { "type": "string", "minLength": 1 },
    "datasetHash": { "type": "string", "minLength": 1 },
    "splitManifestPath": { "type": "string", "minLength": 1 },
    "splitManifestHash": { "type": "string", "minLength": 1 },
    "recordCount": { "type": "integer" },
    "groupCount": { "type": "integer" },
    "splits": { "type": "object" }
  }
}
