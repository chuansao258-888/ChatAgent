{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatagent.local/eval/v2/eval-corpus-manifest.schema.json",
  "title": "ChatAgent Evaluation Corpus Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sourceId", "sourceUrl", "sourceRevision", "license", "licenseUrl", "downloadedAt", "localPath", "files", "counts", "notes"],
  "properties": {
    "schemaVersion": { "type": "integer" },
    "sourceId": { "type": "string", "minLength": 1 },
    "sourceUrl": { "type": "string", "minLength": 1 },
    "sourceRevision": { "type": "string", "minLength": 1 },
    "license": { "type": "string", "minLength": 1 },
    "licenseUrl": { "type": "string", "minLength": 1 },
    "downloadedAt": { "type": "string", "minLength": 1 },
    "localPath": { "type": "string", "minLength": 1 },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "minLength": 1 },
          "bytes": { "type": "integer" },
          "sourceUrl": { "type": "string", "minLength": 1 }
        }
      }
    },
    "counts": { "type": "object" },
    "notes": { "type": "string", "minLength": 1 }
  }
}
