{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatagent.local/eval/v2/eval-parameter-space.schema.json",
  "title": "ChatAgent Evaluation Parameter Space",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "primaryMetric", "direction", "parameters"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "primaryMetric": { "type": "string", "minLength": 1 },
    "direction": { "type": "string", "enum": ["maximize", "minimize"] },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "classification", "type", "values"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "classification": {
            "type": "string",
            "enum": ["quality-tunable", "operational-only", "safety-fixed", "excluded-with-rationale"]
          },
          "type": { "type": "string", "enum": ["integer", "number", "string", "boolean"] },
          "values": { "type": "array", "minItems": 1 },
          "rationale": { "type": ["string", "null"] }
        }
      }
    }
  }
}
