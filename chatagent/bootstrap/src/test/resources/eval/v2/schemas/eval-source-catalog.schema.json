{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatagent.local/eval/v2/eval-source-catalog.schema.json",
  "title": "ChatAgent Evaluation Source Catalog Entry",
  "type": "object",
  "required": ["sourceId", "sourceUrl", "sourceRevision", "license", "licenseUrl", "notes"],
  "properties": {
    "sourceId": { "type": "string", "minLength": 1 },
    "sourceUrl": { "type": "string", "minLength": 1 },
    "sourceRevision": { "type": "string", "minLength": 1 },
    "expectedSha256": { "type": "string", "minLength": 1 },
    "companyFactsUrlTemplate": { "type": "string", "minLength": 1 },
    "submissionsUrlTemplate": { "type": "string", "minLength": 1 },
    "filingUrlTemplate": { "type": "string", "minLength": 1 },
    "license": { "type": "string", "minLength": 1 },
    "licenseUrl": { "type": "string", "minLength": 1 },
    "termsUrl": { "type": "string", "minLength": 1 },
    "notes": { "type": "string", "minLength": 1 }
  }
}
