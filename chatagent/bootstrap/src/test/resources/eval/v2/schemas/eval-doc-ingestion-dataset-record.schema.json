{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eval-doc-ingestion-dataset-record.schema.json",
  "title": "EvalDocIngestionDatasetRecord",
  "description": "Phase 10a production document ingestion retrieval dataset record. Each row represents one evidence-grounded query against real multi-format documents ingested through the production pipeline. Follows the Phase 3 dataset record contract.",
  "type": "object",
  "required": ["sampleId", "datasetId", "sourceGroupId", "split", "userInput", "referenceContextIds", "metadata"],
  "properties": {
    "sampleId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this query row."
    },
    "datasetId": {
      "type": "string",
      "minLength": 1,
      "description": "Dataset identifier (doc-ingestion-retrieval-v1)."
    },
    "sourceGroupId": {
      "type": "string",
      "minLength": 1,
      "description": "Source group identifier (document ID, used for split grouping)."
    },
    "split": {
      "type": "string",
      "enum": ["calibration", "development", "holdout", "challenge"],
      "description": "Dataset split assignment."
    },
    "userInput": {
      "type": "string",
      "minLength": 1,
      "description": "The evidence-grounded query text derived from the reference chunk content."
    },
    "referenceContextIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "description": "The chunk IDs that this query should retrieve. At least one reference chunk ID is required for meaningful chunk-level recall scoring."
    },
    "response": {
      "type": "string",
      "description": "Generated answer text for 10d-B2 RAGAS/control runs. Retrieval-only rows may omit this field."
    },
    "reference": {
      "type": "string",
      "description": "Reference answer text grounded in the reference chunk for 10d-B2 answer metrics. Retrieval-only rows may omit this field."
    },
    "retrievedContexts": {
      "type": "array",
      "description": "Top-level RAGAS-compatible retrieved contexts. The runner also accepts metadata.retrievedContexts for legacy retrieval rows.",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "chunkId": { "type": ["string", "null"] },
          "documentId": { "type": ["string", "null"] },
          "text": { "type": "string" },
          "score": { "type": ["number", "null"] }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "required": ["format", "generationMethod"],
      "description": "Doc-ingestion-specific metadata including source provenance, format, and retrieved contexts.",
      "properties": {
        "format": {
          "type": "string",
          "description": "File format family (TXT, PDF, HTML, MD, DOCX, XLSX, etc.)."
        },
        "referenceContent": {
          "type": "string",
          "description": "Full text content of the reference chunk."
        },
        "referenceAnswer": {
          "type": "string",
          "minLength": 1,
          "description": "Concise reference answer. For manual-reviewed-no-source-v1: human-authored. For llm-generated-llm-reviewed-v1: LLM-generated, validated against referenceContent, and reviewed by a separate Gemini CLI pass."
        },
        "generationMethod": {
          "type": "string",
          "enum": ["manual-reviewed-no-source-v1", "llm-generated-llm-reviewed-v1", "codex-manual-assisted-llm-reviewed-v1", "template-question", "template-question-disambiguated", "direct-evidence-preflight", "direct-evidence-disambiguated", "template"],
          "description": "How the query was authored. Only these values are allowed. manual-reviewed-no-source-v1 = fully human-authored; llm-generated-llm-reviewed-v1 = LLM-generated, validated, and reviewed by a separate LLM pass; template-question = auto-generated from template; direct-evidence-preflight = preflight diagnostic; template = analysis fixture."
        },
        "queryDisambiguation": {
          "type": "object",
          "description": "Legacy-compatible provenance showing that source identity is retained only in metadata and is not applied to userInput.",
          "properties": {
            "enabled": { "enum": [false] },
            "method": { "enum": ["metadata-only-source-identity"] },
            "sourceHint": { "type": "string" }
          },
          "additionalProperties": true
        },
        "questionProvenance": {
          "type": "object",
          "description": "Provenance for the authored userInput and explicit confirmation that source/reference binding data was not injected.",
          "required": ["method", "questionId", "questionSetVersion", "sourceIdentityInjected", "referenceNeedleInjected", "referenceAnswerInjected"],
          "properties": {
            "method": { "enum": ["manual-reviewed-no-source-v1", "llm-assisted-no-source-v1", "codex-manual-assisted-no-source-v1"] },
            "questionId": { "type": "string", "minLength": 1 },
            "questionSetVersion": { "type": "string", "minLength": 1 },
            "sourceIdentityInjected": { "enum": [false] },
            "referenceNeedleInjected": { "enum": [false] },
            "referenceAnswerInjected": { "enum": [false] }
          },
          "additionalProperties": false
        },
        "llmProvenance": {
          "type": ["object", "null"],
          "description": "LLM generation and review provenance. Required and must be non-null when generationMethod is llm-generated-llm-reviewed-v1. Null or absent for manual-reviewed-no-source-v1 rows.",
          "required": ["generatorModel", "generatorTool"],
          "properties": {
            "generatorModel": { "type": "string", "minLength": 1 },
            "generatorTool": { "type": "string", "minLength": 1 },
            "reviewerModel": { "type": "string", "minLength": 1 },
            "reviewerTool": { "type": "string", "minLength": 1 },
            "reviewerPromptVersion": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "auditStatus": {
          "type": ["string", "null"],
          "enum": ["pending", "llm-reviewed", "failed-review", null],
          "description": "Review status of this question. Only llm-reviewed questions appear in the accepted question set file. Null for legacy/auto-generated rows."
        },
        "sourceUrl": {
          "type": ["string", "null"],
          "description": "Original download URL of the source document."
        },
        "sourceSha256": {
          "type": ["string", "null"],
          "description": "SHA-256 hash of the downloaded file content."
        },
        "sourceGroup": {
          "type": ["string", "null"],
          "description": "Source group identifier (e.g., project-gutenberg, sec-edgar, pmc)."
        },
        "license": {
          "type": ["string", "null"],
          "description": "License or terms of the source document."
        },
        "knowledgeBaseId": {
          "type": "string",
          "description": "The eval-owned knowledge base ID used for ingestion."
        },
        "referenceDocId": {
          "type": "string",
          "description": "The document ID containing the reference chunk."
        },
        "referenceDocFilename": {
          "type": "string",
          "description": "Original filename of the source document."
        },
        "retrievedContexts": {
          "type": "array",
          "description": "Top-K retrieved contexts from the production hybrid search with chunk IDs.",
          "items": {
            "type": "object",
            "required": ["chunkId", "documentId", "content"],
            "properties": {
              "chunkId": {
                "type": "string",
                "minLength": 1,
                "description": "The chunk ID for chunk-level metric matching."
              },
              "documentId": {
                "type": ["string", "null"],
                "description": "The document ID of the retrieved chunk."
              },
              "documentName": {
                "type": ["string", "null"]
              },
              "chunkIndex": {
                "type": ["integer", "null"]
              },
              "score": {
                "type": ["number", "null"]
              },
              "scoreType": {
                "type": ["string", "null"],
                "description": "Score source for the final production context, such as reranker, retrieval, or fallback."
              },
              "finalRank": {
                "type": ["integer", "null"],
                "minimum": 1,
                "description": "1-based final rank after production reranking and topK truncation."
              },
              "candidateRank": {
                "type": ["integer", "null"],
                "minimum": 1,
                "description": "1-based rank of the same chunk in the pre-reranker candidate pool when matched."
              },
              "rerankerRank": {
                "type": ["integer", "null"],
                "minimum": 1,
                "description": "1-based final rank assigned after the production reranker path."
              },
              "rerankerScore": {
                "type": ["number", "null"],
                "description": "Final reranker score when the production reranker supplied one."
              },
              "rerankerScoreType": {
                "type": ["string", "null"],
                "description": "Final score type after reranking; fallback indicates the reranker did not score this row."
              },
              "reranked": {
                "type": ["boolean", "null"],
                "description": "True when the final context score came from the reranker."
              },
              "fallbackReason": {
                "type": ["string", "null"],
                "description": "Score type or reason recorded when the reranker did not produce the final score."
              },
              "content": {
                "type": "string"
              }
            }
          }
        },
        "candidateContexts": {
          "type": "array",
          "description": "Candidate pool from the production hybrid search, including raw dense/BM25 rank signals used for replay tuning.",
          "items": {
            "type": "object",
            "required": ["id", "chunkId", "content", "rankSignals"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "chunkId": { "type": "string", "minLength": 1 },
              "documentId": { "type": ["string", "null"] },
              "documentName": { "type": ["string", "null"] },
              "chunkIndex": { "type": ["integer", "null"] },
              "score": { "type": ["number", "null"] },
              "content": { "type": "string" },
              "rankSignals": {
                "type": "object",
                "required": ["candidateRank"],
                "properties": {
                  "candidateRank": { "type": "integer", "minimum": 1 },
                  "denseRank": { "type": ["integer", "null"], "minimum": 1 },
                  "bm25Rank": { "type": ["integer", "null"], "minimum": 1 },
                  "denseScore": { "type": ["number", "null"] },
                  "bm25Score": { "type": ["number", "null"] },
                  "fusedScore": { "type": ["number", "null"] }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        },
        "referenceContexts": {
          "type": "array",
          "description": "Reference context text for RAGAS context recall/precision runs. Items may be strings or context objects.",
          "minItems": 1,
          "items": { "type": ["string", "object"] }
        },
        "sourceSampleId": {
          "type": "string",
          "minLength": 1,
          "description": "Original retrieval sample ID shared by every paired answer-control row."
        },
        "controlRun": {
          "type": "object",
          "description": "10d-B2 answer-control label used to prove the RAG chain helps final answers.",
          "required": ["mode"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["retrieval-only", "no-rag", "full-rag", "wrong-context", "oracle-context", "reranker-off", "reranker-on"]
            },
            "variant": { "type": ["string", "null"] },
            "rerankerEnabled": { "type": ["boolean", "null"] }
          },
          "additionalProperties": true
        },
        "citations": {
          "type": "array",
          "description": "Generated-answer citation evidence. Citation-support metrics compare these IDs to source chunks, not to free-form citation prose.",
          "items": {
            "type": "object",
            "required": ["sourceChunkId"],
            "properties": {
              "sourceChunkId": { "type": "string", "minLength": 1 },
              "marker": { "type": ["string", "null"] },
              "supported": { "type": ["boolean", "null"] }
            },
            "additionalProperties": true
          }
        },
        "latency": {
          "type": "object",
          "description": "Per-row timing for cost/latency guardrails.",
          "properties": {
            "retrievalMs": { "type": ["number", "null"] },
            "rerankerMs": { "type": ["number", "null"] },
            "answerMs": { "type": ["number", "null"] },
            "totalMs": { "type": ["number", "null"] }
          },
          "additionalProperties": true
        },
        "retrievalLatency": {
          "type": "object",
          "description": "Measured Java production retrieval-path timing copied into answer artifacts.",
          "required": ["candidatePathMs", "finalProductionPathMs"],
          "properties": {
            "candidatePathMs": { "type": "number", "minimum": 0 },
            "finalProductionPathMs": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "tokenCounts": {
          "type": "object",
          "description": "Per-row token usage for prompt/cost guardrails.",
          "properties": {
            "promptTokens": { "type": ["integer", "null"] },
            "completionTokens": { "type": ["integer", "null"] },
            "totalTokens": { "type": ["integer", "null"] },
            "retrievedContextTokens": { "type": ["integer", "null"] }
          },
          "additionalProperties": true
        },
        "contextBudget": {
          "type": "object",
          "description": "Recorded context-packing budget and truncation evidence for answer-generation runs.",
          "required": ["budgetTokens", "originalApproxTokens", "includedApproxTokens", "originalContextCount", "includedContextCount", "truncated"],
          "properties": {
            "budgetTokens": { "type": "integer", "minimum": 1 },
            "originalApproxTokens": { "type": "integer", "minimum": 0 },
            "includedApproxTokens": { "type": "integer", "minimum": 0 },
            "originalContextCount": { "type": "integer", "minimum": 0 },
            "includedContextCount": { "type": "integer", "minimum": 0 },
            "truncated": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "answerProvider": {
          "type": "object",
          "description": "Sanitized answer-generation provider/model provenance.",
          "properties": {
            "provider": { "type": "string" },
            "modelName": { "type": "string" }
          },
          "additionalProperties": true
        },
        "retrievalProvenance": {
          "type": "object",
          "description": "Production retrieval paths and bounds used to create candidate and final contexts.",
          "properties": {
            "candidateK": { "type": "integer", "minimum": 1 },
            "finalTopK": { "type": "integer", "minimum": 1 },
            "rrfK": { "type": "integer", "minimum": 1 },
            "rerankerMaxCandidates": { "type": "integer", "minimum": 1 },
            "rerankerExpected": { "type": "boolean" },
            "rerankerProvider": { "type": "string", "minLength": 1 },
            "rerankerModel": { "type": "string", "minLength": 1 },
            "candidatePath": { "type": "string", "minLength": 1 },
            "finalPath": { "type": "string", "minLength": 1 },
            "primaryMetricsSource": { "type": "string" }
          },
          "additionalProperties": true
        },
        "parser": {
          "type": "string",
          "description": "Document parser used (e.g., TikaDocumentParser, PdfDocumentParser)."
        },
        "chunker": {
          "type": "string",
          "description": "Chunker strategy used (e.g., PlainTextChunker, StructureAwareMarkdownChunker)."
        },
        "chunkerTargetChars": {
          "type": "integer",
          "description": "Target chunk size in characters."
        },
        "chunkerOverlapChars": {
          "type": "integer",
          "description": "Chunk overlap in characters."
        },
        "chunkerMaxRowsPerChunk": {
          "type": "integer",
          "description": "Maximum rows per chunk for row-based XLSX chunking."
        },
        "chunkerOverlapRows": {
          "type": "integer",
          "description": "Overlap rows for row-based XLSX chunking."
        },
        "embeddingModel": {
          "type": "string",
          "description": "Embedding model name (e.g., bge-m3)."
        },
        "embeddingProvider": {
          "type": "string",
          "description": "Embedding provider (e.g., ollama)."
        },
        "embeddingDimension": {
          "type": "integer",
          "description": "Embedding vector dimension."
        },
        "vectorIndex": {
          "type": "string",
          "description": "Vector index backend (e.g., milvus)."
        },
        "vectorMetric": {
          "type": "string",
          "description": "Vector similarity metric (e.g., COSINE)."
        },
        "ingestionPath": {
          "type": "string",
          "description": "Ingestion path used (e.g., ingestSync, mq-outbox)."
        },
        "mqEnabled": {
          "type": "boolean",
          "description": "Whether MQ/outbox path was used for ingestion."
        },
        "mineruEnabled": {
          "type": "boolean",
          "description": "Whether MinerU visual-track parsing was used."
        },
        "mq": {
          "type": "object",
          "description": "Outbox/RabbitMQ provenance for accepted full-chain rows.",
          "properties": {
            "outboxEventId": { "type": ["string", "null"] },
            "idempotencyKey": { "type": ["string", "null"] },
            "outboxStatus": { "type": ["string", "null"] },
            "consumerCompleted": { "type": "boolean" },
            "parseStatus": { "type": "string" },
            "chunkCount": { "type": "integer", "minimum": 1 },
            "milvusInserted": { "type": "boolean" },
            "outboxCreatedAt": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "mineru": {
          "type": "object",
          "description": "MinerU/VDP route provenance for PDF or visual-track rows.",
          "properties": {
            "enabled": { "type": "boolean" },
            "selected": { "type": "boolean" },
            "engineId": { "type": ["string", "null"] },
            "visualChunkCount": { "type": "integer", "minimum": 0 },
            "evidenceFields": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "metadata": {
            "required": ["generationMethod"],
            "properties": {
              "generationMethod": {
                "enum": ["manual-reviewed-no-source-v1"]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "required": ["queryDisambiguation", "questionProvenance", "referenceAnswer"],
            "properties": {
              "questionProvenance": {
                "properties": {
                  "method": { "enum": ["manual-reviewed-no-source-v1"] }
                }
              },
              "llmProvenance": {
                "type": "null",
                "description": "Manual-reviewed rows must not carry LLM provenance."
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "required": ["controlRun"]
          }
        }
      },
      "then": {
        "required": ["response", "reference"],
        "properties": {
          "metadata": {
            "required": ["referenceContexts", "sourceSampleId"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "required": ["controlRun"],
            "properties": {
              "controlRun": {
                "required": ["mode"],
                "properties": {
                  "mode": {
                    "enum": ["full-rag", "wrong-context", "oracle-context", "reranker-off", "reranker-on"]
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "required": ["retrievedContexts"],
        "properties": {
          "retrievedContexts": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "required": ["generationMethod"],
            "properties": {
              "generationMethod": {
                "enum": ["llm-generated-llm-reviewed-v1"]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "required": ["queryDisambiguation", "questionProvenance", "referenceAnswer", "llmProvenance", "auditStatus"],
            "properties": {
              "llmProvenance": {
                "type": "object",
                "required": ["generatorModel", "generatorTool", "reviewerModel", "reviewerTool", "reviewerPromptVersion"],
                "properties": {
                  "generatorModel": { "type": "string", "minLength": 1 },
                  "generatorTool": { "type": "string", "minLength": 1 },
                  "reviewerModel": { "type": "string", "minLength": 1 },
                  "reviewerTool": { "type": "string", "minLength": 1 },
                  "reviewerPromptVersion": { "type": "string", "minLength": 1 }
                }
              },
              "auditStatus": {
                "type": "string",
                "enum": ["llm-reviewed"]
              },
              "questionProvenance": {
                "properties": {
                  "method": { "enum": ["llm-assisted-no-source-v1"] }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "required": ["generationMethod"],
            "properties": {
              "generationMethod": {
                "enum": ["codex-manual-assisted-llm-reviewed-v1"]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "metadata": {
            "required": ["queryDisambiguation", "questionProvenance", "referenceAnswer", "llmProvenance", "auditStatus"],
            "properties": {
              "llmProvenance": {
                "type": "object",
                "required": ["generatorModel", "generatorTool", "reviewerModel", "reviewerTool", "reviewerPromptVersion"],
                "properties": {
                  "generatorModel": { "type": "string", "minLength": 1 },
                  "generatorTool": { "type": "string", "minLength": 1 },
                  "reviewerModel": { "type": "string", "minLength": 1 },
                  "reviewerTool": { "type": "string", "minLength": 1 },
                  "reviewerPromptVersion": { "type": "string", "minLength": 1 }
                }
              },
              "auditStatus": {
                "type": "string",
                "enum": ["llm-reviewed"]
              },
              "questionProvenance": {
                "properties": {
                  "method": { "enum": ["codex-manual-assisted-no-source-v1"] }
                }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
