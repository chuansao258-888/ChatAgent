{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatagent.local/eval/v2/eval-text-recall-dataset-record.schema.json",
  "title": "ChatAgent Text Recall Dataset Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["sampleId", "datasetId", "sourceGroupId", "split", "sourceUrl", "sourceFile", "mediaType", "requiredPhrases", "metadata"],
  "properties": {
    "sampleId": { "type": "string", "minLength": 1 },
    "datasetId": { "type": "string", "minLength": 1 },
    "sourceGroupId": { "type": "string", "minLength": 1 },
    "split": { "type": "string", "enum": ["calibration", "development", "holdout", "challenge"] },
    "sourceUrl": { "type": "string", "minLength": 1 },
    "sourceFile": { "type": "string", "minLength": 1 },
    "mediaType": { "type": "string", "minLength": 1 },
    "requiredPhrases": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "metadata": { "type": "object" }
  }
}
