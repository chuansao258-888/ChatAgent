{
  "schemaVersion": 1,
  "registryId": "chatagent-eval-parameter-registry-v1",
  "parameters": [
    {
      "id": "rag.retrieval.topK",
      "owner": "rag-retrieval",
      "source": "application.yaml",
      "runtimeProperty": "rag.retrieval.top-k",
      "environmentVariable": "CHATAGENT_RAG_TOP_K",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 3,
      "validRange": { "min": 1 },
      "constraints": ["topK <= candidateK"],
      "suites": ["rag-retrieval"],
      "metrics": ["ndcgAtK", "recallAtK", "mrr"],
      "parameterSpaceId": "rag-retrieval-v1",
      "spaceParameterId": "topK",
      "promotionStatus": "current",
      "rationale": "Final retrieval context depth directly affects recall and precision."
    },
    {
      "id": "rag.retrieval.candidateK",
      "owner": "rag-retrieval",
      "source": "application.yaml",
      "runtimeProperty": "rag.retrieval.candidate-k",
      "environmentVariable": "CHATAGENT_RAG_CANDIDATE_K",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 12,
      "validRange": { "min": 1 },
      "constraints": ["candidateK >= topK"],
      "suites": ["rag-retrieval"],
      "metrics": ["ndcgAtK", "recallAtK", "mrr"],
      "parameterSpaceId": "rag-retrieval-v1",
      "spaceParameterId": "candidateK",
      "promotionStatus": "current",
      "rationale": "Candidate depth controls the evidence pool before fusion and reranking."
    },
    {
      "id": "rag.retrieval.rrfK",
      "owner": "rag-retrieval",
      "source": "application.yaml",
      "runtimeProperty": "rag.retrieval.rrf-k",
      "environmentVariable": "CHATAGENT_RAG_RRF_K",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 60,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["rag-retrieval"],
      "metrics": ["ndcgAtK", "recallAtK", "mrr"],
      "parameterSpaceId": "rag-retrieval-v1",
      "spaceParameterId": "rrfK",
      "promotionStatus": "current",
      "rationale": "RRF smoothing can change hybrid retrieval ordering."
    },
    {
      "id": "rag.reranker.maxCandidates",
      "owner": "rag-retrieval",
      "source": "application.yaml",
      "runtimeProperty": "rag.retrieval.reranker.max-candidates",
      "environmentVariable": "CHATAGENT_RAG_RERANKER_MAX_CANDIDATES",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 8,
      "validRange": { "min": 1 },
      "constraints": ["maxCandidates <= candidateK"],
      "suites": ["rag-retrieval"],
      "metrics": ["ndcgAtK", "recallAtK"],
      "parameterSpaceId": "rag-retrieval-reranker-v1",
      "spaceParameterId": "maxCandidates",
      "promotionStatus": "deferred",
      "rationale": "Requires a live reranker parameter space before promotion."
    },
    {
      "id": "rag.reranker.maxChunkChars",
      "owner": "rag-retrieval",
      "source": "application.yaml",
      "runtimeProperty": "rag.retrieval.reranker.max-chunk-chars",
      "environmentVariable": "CHATAGENT_RAG_RERANKER_MAX_CHUNK_CHARS",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 900,
      "validRange": { "min": 100 },
      "constraints": [],
      "suites": ["rag-retrieval"],
      "metrics": ["ndcgAtK", "latencyP95Ms"],
      "parameterSpaceId": "rag-retrieval-reranker-v1",
      "spaceParameterId": "maxChunkChars",
      "promotionStatus": "deferred",
      "rationale": "Requires a live reranker parameter space before promotion."
    },
    {
      "id": "rag.reranker.scoreThreshold",
      "owner": "rag-retrieval",
      "source": "application.yaml",
      "runtimeProperty": "rag.retrieval.reranker.score-threshold",
      "environmentVariable": "CHATAGENT_RAG_RERANKER_SCORE_THRESHOLD",
      "classification": "quality-tunable",
      "type": "number",
      "default": 0.08,
      "validRange": { "min": 0.0, "max": 1.0 },
      "constraints": [],
      "suites": ["rag-retrieval"],
      "metrics": ["precisionAtK", "recallAtK"],
      "parameterSpaceId": "rag-retrieval-reranker-v1",
      "spaceParameterId": "scoreThreshold",
      "promotionStatus": "deferred",
      "rationale": "Requires live reranker scoring before it can be tuned."
    },
    {
      "id": "rag.reranker.maxConnections",
      "owner": "rag-retrieval",
      "source": "application.yaml",
      "runtimeProperty": "rag.retrieval.reranker.max-connections",
      "environmentVariable": "CHATAGENT_RAG_RERANKER_MAX_CONNECTIONS",
      "classification": "operational-only",
      "type": "integer",
      "default": 10,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["reliability"],
      "metrics": ["throughput", "latencyP95Ms"],
      "promotionStatus": "not-applicable",
      "rationale": "Connection-pool sizing belongs to reliability and load testing, not accuracy selection."
    },
    {
      "id": "rag.reranker.failureThreshold",
      "owner": "rag-retrieval",
      "source": "application.yaml",
      "runtimeProperty": "rag.retrieval.reranker.failure-threshold",
      "environmentVariable": "CHATAGENT_RAG_RERANKER_FAILURE_THRESHOLD",
      "classification": "safety-fixed",
      "type": "integer",
      "default": 5,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["reliability"],
      "metrics": ["availability"],
      "promotionStatus": "not-applicable",
      "rationale": "Circuit-breaker behavior must not be selected by an accuracy optimizer."
    },
    {
      "id": "textRecall.chunkSize",
      "owner": "text-recall",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 2000,
      "validRange": { "min": 1 },
      "constraints": ["chunkOverlap < chunkSize"],
      "suites": ["text-recall"],
      "metrics": ["textRecall.chunkSpanRecall", "textRecall.retrievalContextPhraseRecall"],
      "parameterSpaceId": "text-recall-v1",
      "spaceParameterId": "chunkSize",
      "promotionStatus": "current",
      "rationale": "Chunk size affects phrase preservation and retrieval context quality."
    },
    {
      "id": "textRecall.chunkOverlap",
      "owner": "text-recall",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 200,
      "validRange": { "min": 0 },
      "constraints": ["chunkOverlap < chunkSize"],
      "suites": ["text-recall"],
      "metrics": ["textRecall.chunkSpanRecall", "textRecall.retrievalContextPhraseRecall"],
      "parameterSpaceId": "text-recall-v1",
      "spaceParameterId": "chunkOverlap",
      "promotionStatus": "current",
      "rationale": "Overlap controls boundary phrase preservation."
    },
    {
      "id": "textRecall.topK",
      "owner": "text-recall",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 5,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["text-recall"],
      "metrics": ["textRecall.retrievalContextPhraseRecall", "textRecall.citationSupportRecall"],
      "parameterSpaceId": "text-recall-v1",
      "spaceParameterId": "topK",
      "promotionStatus": "current",
      "rationale": "Retrieved context depth directly affects recall."
    },
    {
      "id": "memory.l1WindowTurns",
      "owner": "memory-v2",
      "source": "application.yaml and tools/eval",
      "runtimeProperty": "chatagent.memory.l1-window-turns",
      "environmentVariable": "CHATAGENT_MEMORY_L1_WINDOW_TURNS",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 8,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["memory-v2"],
      "metrics": ["memory.l1CompleteTurnRecall"],
      "parameterSpaceId": "memory-v2-v1",
      "spaceParameterId": "l1WindowTurns",
      "promotionStatus": "current",
      "rationale": "Recent-turn depth affects complete-turn preservation."
    },
    {
      "id": "memory.l1BudgetChars",
      "owner": "memory-v2",
      "source": "tools/eval proxy for runtime token budget",
      "runtimeProperty": "chatagent.memory.l1-token-budget",
      "environmentVariable": "CHATAGENT_MEMORY_L1_TOKEN_BUDGET",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 8000,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["memory-v2"],
      "metrics": ["memory.l1CompleteTurnRecall", "memory.l1BudgetCompliance"],
      "parameterSpaceId": "memory-v2-v1",
      "spaceParameterId": "l1BudgetChars",
      "promotionStatus": "candidate",
      "rationale": "The deterministic runner uses a character-budget proxy until token-budget export is available."
    },
    {
      "id": "memory.l2SegmentTurns",
      "owner": "memory-v2",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 4,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["memory-v2"],
      "metrics": ["memory.l2FactRecall", "memory.l2SegmentRangeCoverage"],
      "parameterSpaceId": "memory-v2-v1",
      "spaceParameterId": "l2SegmentTurns",
      "promotionStatus": "candidate",
      "rationale": "Segment size affects L2 summary coverage and audit granularity."
    },
    {
      "id": "memory.l3TopK",
      "owner": "memory-v2",
      "source": "application.yaml and tools/eval",
      "runtimeProperty": "chatagent.memory.l3.recall-top-k",
      "environmentVariable": "CHATAGENT_MEMORY_L3_RECALL_TOP_K",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 3,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["memory-v2"],
      "metrics": ["memory.l3RecallHitAtK", "memory.l3RecallMrr"],
      "parameterSpaceId": "memory-v2-v1",
      "spaceParameterId": "l3TopK",
      "promotionStatus": "current",
      "rationale": "L3 recall depth changes durable-memory hit rate."
    },
    {
      "id": "memory.summaryMaxChars",
      "owner": "memory-v2",
      "source": "application.yaml",
      "runtimeProperty": "chatagent.memory.summary-max-chars",
      "environmentVariable": "CHATAGENT_MEMORY_SUMMARY_MAX_CHARS",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 500,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["memory-v2"],
      "metrics": ["memory.l2FactRecall", "memory.l2FactPrecision"],
      "parameterSpaceId": "memory-v2-runtime-v1",
      "spaceParameterId": "summaryMaxChars",
      "promotionStatus": "deferred",
      "rationale": "Requires a provider-backed compaction export before tuning."
    },
    {
      "id": "memory.compaction.maxRetries",
      "owner": "memory-v2",
      "source": "application.yaml",
      "runtimeProperty": "chatagent.memory.compaction.v2.max-retries",
      "environmentVariable": "CHATAGENT_MEMORY_COMPACTION_V2_MAX_RETRIES",
      "classification": "operational-only",
      "type": "integer",
      "default": 2,
      "validRange": { "min": 0 },
      "constraints": [],
      "suites": ["reliability"],
      "metrics": ["memory.l2RetryCount"],
      "promotionStatus": "not-applicable",
      "rationale": "Retry policy belongs to reliability gates, not accuracy optimization."
    },
    {
      "id": "memory.compaction.maxConsecutiveFailures",
      "owner": "memory-v2",
      "source": "application.yaml",
      "runtimeProperty": "chatagent.memory.compaction.v2.max-consecutive-failures",
      "environmentVariable": "CHATAGENT_MEMORY_COMPACTION_V2_MAX_CONSECUTIVE_FAILURES",
      "classification": "safety-fixed",
      "type": "integer",
      "default": 3,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["reliability"],
      "metrics": ["availability"],
      "promotionStatus": "not-applicable",
      "rationale": "Failure cutoff is a safety/reliability decision."
    },
    {
      "id": "agentModules.intentHistoryTurns",
      "owner": "agent-modules",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 6,
      "validRange": { "min": 0 },
      "constraints": [],
      "suites": ["agent-modules"],
      "metrics": ["agentModules.intentExactPathAccuracy"],
      "parameterSpaceId": "agent-modules-v1",
      "spaceParameterId": "intentHistoryTurns",
      "promotionStatus": "candidate",
      "rationale": "Controls available dialogue evidence for intent routing diagnostics."
    },
    {
      "id": "agentModules.intentMinEvidenceTerms",
      "owner": "agent-modules",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 1,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["agent-modules"],
      "metrics": ["agentModules.intentExactPathAccuracy"],
      "parameterSpaceId": "agent-modules-v1",
      "spaceParameterId": "intentMinEvidenceTerms",
      "promotionStatus": "candidate",
      "rationale": "Controls minimum historical evidence for multi-turn intent paths."
    },
    {
      "id": "agentModules.rewriteHistoryTurns",
      "owner": "agent-modules",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 6,
      "validRange": { "min": 0 },
      "constraints": [],
      "suites": ["agent-modules"],
      "metrics": ["agentModules.rewriteAnchorRecall"],
      "parameterSpaceId": "agent-modules-v1",
      "spaceParameterId": "rewriteHistoryTurns",
      "promotionStatus": "candidate",
      "rationale": "Controls history available to query rewrite diagnostics."
    },
    {
      "id": "agentModules.rewriteMaxAnchors",
      "owner": "agent-modules",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 3,
      "validRange": { "min": 0 },
      "constraints": [],
      "suites": ["agent-modules"],
      "metrics": ["agentModules.rewriteAnchorRecall", "agentModules.rewriteRetrievalLiftRate"],
      "parameterSpaceId": "agent-modules-v1",
      "spaceParameterId": "rewriteMaxAnchors",
      "promotionStatus": "candidate",
      "rationale": "Controls how much real dialogue context enters a rewritten query."
    },
    {
      "id": "agentModules.rewriteMaxExtraTerms",
      "owner": "agent-modules",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 0,
      "validRange": { "min": 0 },
      "constraints": [],
      "suites": ["agent-modules"],
      "metrics": ["agentModules.rewriteNoOverExpansionRate"],
      "parameterSpaceId": "agent-modules-v1",
      "spaceParameterId": "rewriteMaxExtraTerms",
      "promotionStatus": "candidate",
      "rationale": "Controls tolerated query expansion beyond approved anchors."
    },
    {
      "id": "agentModules.toolCandidateLimit",
      "owner": "agent-modules",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 1,
      "validRange": { "min": 0 },
      "constraints": [],
      "suites": ["agent-modules"],
      "metrics": ["agentModules.toolCallF1"],
      "parameterSpaceId": "agent-modules-v1",
      "spaceParameterId": "toolCandidateLimit",
      "promotionStatus": "candidate",
      "rationale": "Controls whether expected knowledge-search calls can be emitted."
    },
    {
      "id": "agentModules.multiturnCorefWindowTurns",
      "owner": "agent-modules",
      "source": "tools/eval",
      "classification": "quality-tunable",
      "type": "integer",
      "default": 6,
      "validRange": { "min": 0 },
      "constraints": [],
      "suites": ["agent-modules"],
      "metrics": ["agentModules.coreferenceRecall"],
      "parameterSpaceId": "agent-modules-v1",
      "spaceParameterId": "multiturnCorefWindowTurns",
      "promotionStatus": "candidate",
      "rationale": "Controls history available to multi-turn coreference diagnostics."
    },
    {
      "id": "intent.minimumScore",
      "owner": "intent-runtime",
      "source": "application.yaml",
      "runtimeProperty": "chatagent.intent.minimum-score",
      "classification": "quality-tunable",
      "type": "number",
      "default": 0.45,
      "validRange": { "min": 0.0, "max": 1.0 },
      "constraints": [],
      "suites": ["agent-modules"],
      "metrics": ["agentModules.intentExactPathAccuracy"],
      "parameterSpaceId": "intent-runtime-v1",
      "spaceParameterId": "minimumScore",
      "promotionStatus": "deferred",
      "rationale": "Requires live intent classifier scores before tuning."
    },
    {
      "id": "intent.ambiguityGap",
      "owner": "intent-runtime",
      "source": "application.yaml",
      "runtimeProperty": "chatagent.intent.ambiguity-gap",
      "classification": "quality-tunable",
      "type": "number",
      "default": 0.2,
      "validRange": { "min": 0.0, "max": 1.0 },
      "constraints": [],
      "suites": ["agent-modules"],
      "metrics": ["agentModules.intentAmbiguityAccuracy"],
      "parameterSpaceId": "intent-runtime-v1",
      "spaceParameterId": "ambiguityGap",
      "promotionStatus": "deferred",
      "rationale": "Requires live intent classifier scores before tuning."
    },
    {
      "id": "generation.deepseekMaxTokens",
      "owner": "generation",
      "source": "application.yaml",
      "runtimeProperty": "spring.ai.openai.chat.options.max-tokens",
      "environmentVariable": "CHATAGENT_DEEPSEEK_MAX_TOKENS",
      "classification": "excluded-with-rationale",
      "type": "integer",
      "default": 2048,
      "validRange": { "min": 1 },
      "constraints": [],
      "suites": ["ragas-quality"],
      "metrics": ["ragas.answerRelevancy"],
      "promotionStatus": "deferred",
      "rationale": "Excluded until a real answer-generation dataset and frozen judge experiment are available."
    }
  ]
}
