{
  "title": "ChatAgent Routing",
  "uid": "chatagent-routing",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "tags": ["chatagent", "llm", "routing"],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(chatagent_llm_routing_attempts_total, job)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {"text": "All", "value": ".*"}
      },
      {
        "name": "model",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(chatagent_llm_routing_attempts_total{job=~\"$job\"}, model)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {"text": "All", "value": ".*"}
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Routing Attempts",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (mode, outcome) (rate(chatagent_llm_routing_attempts_total{job=~\"$job\",model=~\"$model\"}[5m]))",
          "legendFormat": "{{mode}} / {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Routing Latency Average",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (mode, model) (rate(chatagent_llm_routing_latency_seconds_sum{job=~\"$job\",model=~\"$model\"}[5m])) / clamp_min(sum by (mode, model) (rate(chatagent_llm_routing_latency_seconds_count{job=~\"$job\",model=~\"$model\"}[5m])), 0.001)",
          "legendFormat": "{{model}} / {{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "First Packet Failure Ratio",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(chatagent_llm_routing_attempts_total{job=~\"$job\",model=~\"$model\",mode=\"stream_first_packet\",outcome!=\"success\"}[5m])) / clamp_min(sum(rate(chatagent_llm_routing_attempts_total{job=~\"$job\",model=~\"$model\",mode=\"stream_first_packet\"}[5m])), 0.001)",
          "legendFormat": "failure ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Circuit Events",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum by (model, event) (increase(chatagent_llm_circuit_events_total{job=~\"$job\",model=~\"$model\"}[5m]))",
          "legendFormat": "{{model}} / {{event}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Circuit Decisions",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum by (model, decision) (rate(chatagent_llm_circuit_decisions_total{job=~\"$job\",model=~\"$model\"}[5m]))",
          "legendFormat": "{{model}} / {{decision}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Routing Latency P95",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, model, mode) (rate(chatagent_llm_routing_latency_seconds_bucket{job=~\"$job\",model=~\"$model\"}[5m])))",
          "legendFormat": "{{model}} / {{mode}}",
          "refId": "A"
        }
      ]
    }
  ]
}
